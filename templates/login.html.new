<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Login - E-Healthcare</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="{{ url_for('static', filename='css/style.css') }}?v=3" />
    <style>
      /* small critical overrides */
      body { background: #f4f7f9; color: #111827 }
      .tab-toggle .tab { cursor: default }
    </style>
  </head>
  <body>
    <div class="container auth-container">
      <div class="row justify-content-center">
        <div class="col-11 col-sm-10 col-md-8 col-lg-7">
          <div class="auth-card">
            <div class="tab-toggle mb-3" role="tablist" aria-label="auth tabs">
              <button class="tab active" type="button">Login</button>
              <button class="tab" type="button">Signup</button>
            </div>

            <div class="auth-inner">
              <div class="auth-info d-none d-md-flex">
                <h2 class="auth-title">Login Form</h2>
                <p class="text-muted mb-0">Enter your credentials to access your account.</p>
              </div>

              <div class="auth-form w-100">
                <div id="messages">
                  {% with messages = get_flashed_messages(with_categories=true) %}
                    {% if messages %}
                      {% for category, msg in messages %}
                        <div class="alert alert-{{ category }}" role="alert">{{ msg }}</div>
                      {% endfor %}
                    {% endif %}
                  {% endwith %}
                </div>

                <form id="login-form" method="post" action="/login" novalidate>
                  <div class="mb-3">
                    <input placeholder="Email Address" type="email" class="form-control form-input-large" id="login-email" name="email" required />
                  </div>

                  <div class="mb-2">
                    <input placeholder="Password" type="password" class="form-control form-input-large" id="login-password" name="password" required />
                  </div>

                  <div class="mb-3 text-end">
                    <a href="#" class="small text-primary">Forgot password?</a>
                  </div>

                  <button type="submit" class="btn btn-big mb-2" id="login-submit">Login</button>

                  <p class="text-center small mb-0">Create an account <a href="/register" id="login-register-link">Signup now</a></p>
                </form>
              </div>
            </div>

          </div>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
